generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum RoutineType {
  MORNING
  EVENING
  CUSTOM
}

enum MemoryCat {
  GOAL
  PREFERENCE
  PATTERN
  MILESTONE
  CONTEXT
}

enum MessageRole {
  USER
  ASSISTANT
}

enum UserRole {
  USER
  ADMIN
}

enum WatchType {
  FIRST_WATCH
  NIGHT_WATCH
}

enum DimCategory {
  DECISION
  IDEA
  MICRO_TASK
}

enum DimStatus {
  OPEN
  COMPLETED
  DEFERRED
  DELEGATED
  DELETED
}

enum DimRecommendation {
  DO
  DEFER
  DELEGATE
  DELETE
}

model User {
  id              String    @id @default(cuid())
  supabase_id     String    @unique
  email           String    @unique
  name            String?
  onboarding_done Boolean   @default(false)
  role            UserRole  @default(USER)
  timezone        String    @default("Europe/Amsterdam")
  locale          String    @default("en") // "en" | "nl"
  notify_enabled    Boolean   @default(false)
  notify_time       String?   // e.g. "07:00"
  first_watch_time  String?   // e.g. "07:00"
  night_watch_time  String?   // e.g. "21:00"
  hourly_gps_enabled    Boolean  @default(true)
  hourly_gps_interval   Int      @default(60) // minutes between check-ins
  hourly_gps_start_time String?  // e.g. "09:00"
  hourly_gps_end_time   String?  // e.g. "18:00"
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt

  routines        Routine[]
  daily_logs      DailyLog[]
  check_ins       CheckIn[]
  memory_entries  MemoryEntry[]
  goals           Goal[]
  conversations   Conversation[]
  weekly_summaries WeeklySummary[]
  push_tokens     PushToken[]
  watches         Watch[]
  dims            Dim[]
  priority_filters PriorityFilter[]
  hourly_checkins HourlyCheckin[]

  @@map("users")
}

model Routine {
  id         String      @id @default(cuid())
  user_id    String
  name       String
  type       RoutineType
  is_active  Boolean     @default(true)
  sort_order Int         @default(0)
  created_at DateTime    @default(now())
  updated_at DateTime    @updatedAt

  user  User          @relation(fields: [user_id], references: [id], onDelete: Cascade)
  items RoutineItem[]

  @@map("routines")
}

model RoutineItem {
  id              String   @id @default(cuid())
  routine_id      String
  name            String
  duration_minutes Int
  sort_order      Int      @default(0)
  is_active       Boolean  @default(true)
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  routine    Routine    @relation(fields: [routine_id], references: [id], onDelete: Cascade)
  daily_logs DailyLog[]

  @@map("routine_items")
}

model DailyLog {
  id              String   @id @default(cuid())
  user_id         String
  routine_item_id String
  date            DateTime @db.Date
  completed       Boolean  @default(true)
  completed_at    DateTime @default(now())
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  user         User        @relation(fields: [user_id], references: [id], onDelete: Cascade)
  routine_item RoutineItem @relation(fields: [routine_item_id], references: [id], onDelete: Cascade)

  @@unique([user_id, routine_item_id, date])
  @@map("daily_logs")
}

model CheckIn {
  id         String   @id @default(cuid())
  user_id    String
  date       DateTime @db.Date
  energy     Int      // 1-5
  focus      Int      // 1-5
  mood       Int      // 1-5
  note       String?
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([user_id, date])
  @@map("check_ins")
}

model MemoryEntry {
  id         String    @id @default(cuid())
  user_id    String
  category   MemoryCat
  content    String
  source     String    // e.g. "onboarding", "chat", "checkin"
  relevance  Float     @default(1.0)
  expires_at DateTime?
  created_at DateTime  @default(now())
  updated_at DateTime  @updatedAt

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("memory_entries")
}

model Goal {
  id         String   @id @default(cuid())
  user_id    String
  title      String
  is_active  Boolean  @default(true)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)
  dims Dim[]

  @@map("goals")
}

model Conversation {
  id         String   @id @default(cuid())
  user_id    String
  date       DateTime @db.Date
  summary    String?
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  user     User      @relation(fields: [user_id], references: [id], onDelete: Cascade)
  messages Message[]

  @@unique([user_id, date])
  @@map("conversations")
}

model Message {
  id              String      @id @default(cuid())
  conversation_id String
  role            MessageRole
  content         String
  created_at      DateTime    @default(now())
  updated_at      DateTime    @updatedAt

  conversation Conversation @relation(fields: [conversation_id], references: [id], onDelete: Cascade)

  @@map("messages")
}

model WeeklySummary {
  id             String   @id @default(cuid())
  user_id        String
  week_start     DateTime @db.Date
  summary        String
  highlights     String[] // array of strings
  suggestions    String[] // array of strings
  avg_energy     Float?
  avg_focus      Float?
  avg_mood       Float?
  completion_pct Float?
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([user_id, week_start])
  @@map("weekly_summaries")
}

model PushToken {
  id         String   @id @default(cuid())
  user_id    String
  token      String   @unique
  platform   String   // "web" | "fcm"
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("push_tokens")
}

model Watch {
  id         String    @id @default(cuid())
  user_id    String
  date       DateTime  @db.Date
  type       WatchType
  status     String    @default("draft") // draft | confirmed
  sections   Json      // structured sections data
  ai_draft   String?   // raw AI-generated markdown
  created_at DateTime  @default(now())
  updated_at DateTime  @updatedAt

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([user_id, date, type])
  @@map("watches")
}

model HourlyCheckin {
  id         String   @id @default(cuid())
  user_id    String
  date       DateTime @db.Date
  time       DateTime // actual timestamp of check-in
  working_on String
  drift_note String?
  win        String?
  energy     Int?     // 1-5
  next_plan  String?
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("hourly_checkins")
}

model Dim {
  id              String            @id @default(cuid())
  user_id         String
  content         String
  category        DimCategory       @default(IDEA)
  status          DimStatus         @default(OPEN)
  priority_score  Int?              // 0-100
  recommendation  DimRecommendation?
  ai_reasoning    String?
  source          String            @default("manual") // manual | chat | watch
  related_goal_id String?
  created_at      DateTime          @default(now())
  completed_at    DateTime?
  updated_at      DateTime          @updatedAt

  user         User  @relation(fields: [user_id], references: [id], onDelete: Cascade)
  related_goal Goal? @relation(fields: [related_goal_id], references: [id], onDelete: SetNull)

  @@map("dims")
}

model PriorityFilter {
  id         String   @id @default(cuid())
  user_id    String
  name       String
  weight     Int      @default(5) // 1-10
  is_active  Boolean  @default(true)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("priority_filters")
}

model AdminPrompt {
  id         String   @id @default(cuid())
  key        String   @unique // e.g. "coach_system", "weekly_summary"
  name       String
  content    String
  is_active  Boolean  @default(true)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@map("admin_prompts")
}
